@model SistemaEstacionamento.Main.Models.Usuario

@{
    ViewData["Title"] = "Editar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Editar</h1>

<h4>Usuario</h4>
<hr />
<div class="row">
    <div class="col-12">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="row mb-3">
                <div class="form-group col-md-3 col-sm-6 mb-3 mb-md-0">
                    <label asp-for="Nome" class="control-label"></label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>
                <div class="form-group col-md-3 col-sm-6 mb-3 mb-md-0">
                    <label asp-for="Login" class="control-label"></label>
                    <input asp-for="Login" class="form-control" />
                    <span asp-validation-for="Login" class="text-danger"></span>
                </div>
                <div class="form-group col-md-3 col-sm-6 mb-3 mb-md-0">
                    <label asp-for="Senha" class="control-label"></label>
                    <input type="password" asp-for="Senha" class="form-control" />
                    <span asp-validation-for="Senha" class="text-danger"></span>
                </div>
                <div class="form-group col-md-3 col-sm-6 mb-3 mb-md-0">
                    <label asp-for="Email" class="control-label"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>                    
                </div>              
            </div>
            <div class="row mb-3">
                <div class="form-group col-md-3 col-sm-6 mb-3 mb-md-0">
                    <label asp-for="IndAtivo" class="control-label form-check-label"></label>
                    <input asp-for="IndAtivo" type="checkbox" class="form-check-input" />
                    @* <span asp-validation-for="IndAtivo.Value" class="text-danger"></span> *@
                </div>
            </div>
          
            <div class="row mb-3">
                <div class="form-group col-md-4 col-sm-6 mb-2 mb-md-0">
                    <input type="submit" value="Salvar" class="btn btn-primary w-100" />
                </div>
                <div class="form-group col-md-4 col-sm-6">
                    <button asp-action="Index" class="btn btn-secondary w-100">Voltar</button>
                </div>
            </div>
        </form>
    </div>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
