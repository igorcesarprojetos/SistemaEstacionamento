@model SistemaEstacionamento.Main.Models.Estacionamento

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Estacionamento</h4>
<hr />

<div class="row">
    <div class="col-12">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <!-- Primeira linha responsiva -->
            <div class="row mb-3">
                <div class="col-md-3 col-sm-6 mb-3 mb-md-0">
                    <label asp-for="PrecoInicial" class="form-label"></label>
                    <input asp-for="PrecoInicial" class="form-control" />
                    <span asp-validation-for="PrecoInicial" class="text-danger"></span>
                </div>
                <div class="col-md-3 col-sm-6 mb-3 mb-md-0">
                    <label asp-for="PrecoHora" class="form-label"></label>
                    <input asp-for="PrecoHora" class="form-control" />
                    <span asp-validation-for="PrecoHora" class="text-danger"></span>
                </div>
                <div class="col-md-3 col-sm-6 mb-3 mb-md-0">
                    <label asp-for="QuantidadeHoras" class="form-label"></label>
                    <input asp-for="QuantidadeHoras" class="form-control" />
                    <span asp-validation-for="QuantidadeHoras" class="text-danger"></span>
                </div>
                <div class="col-md-3 col-sm-6">
                    <label asp-for="ValorTotal" class="form-label"></label>
                    <input asp-for="ValorTotal" class="form-control" readonly disabled="disabled" />
                </div>
            </div>

            <!-- Segunda linha responsiva -->
            <div class="row mb-3">
                <div class="col-md-4 col-sm-6 mb-3 mb-md-0">
                    <label asp-for="PlacaVeiculo" class="form-label"></label>
                    <input asp-for="PlacaVeiculo" class="form-control" />
                    <span asp-validation-for="PlacaVeiculo" class="text-danger"></span>
                </div>
                <div class="col-md-4 col-sm-6 mb-3 mb-md-0">
                    <label asp-for="ModeloVeiculo" class="form-label"></label>
                    <input asp-for="ModeloVeiculo" class="form-control" />
                    <span asp-validation-for="ModeloVeiculo" class="text-danger"></span>
                </div>
                <div class="col-md-4 col-sm-6 d-flex align-items-end">
                    <div class="form-check mt-3">
                        <input asp-for="Pago" type="checkbox" class="form-check-input" />
                        <label asp-for="Pago" class="form-check-label"></label>
                    </div>
                </div>
            </div>

            <!-- Botões -->
            <div class="row mb-3">
                <div class="col-md-4 col-sm-6 mb-2 mb-md-0">
                    <button type="submit" class="btn btn-primary w-100">Salvar</button>
                </div>
                <div class="col-md-4 col-sm-6">
                    <a asp-action="Index" class="btn btn-secondary w-100">Voltar</a>                   
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}